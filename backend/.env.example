# URL pubblico del backend (deve coincidere con i redirect OAuth registrati su Google/GitHub)
BACKEND_PUBLIC_URL=https://voicemint-backend.onrender.com

# URL del frontend (dove si torna dopo il login OAuth)
FRONTEND_URL=https://www.voicemint.it

# Google OAuth (Console → Credenziali → ID client OAuth 2.0)
# Redirect autorizzato: {BACKEND_PUBLIC_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Settings → Developer settings → OAuth Apps)
# Authorization callback URL: {BACKEND_PUBLIC_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Opzionale: cookie sessione OAuth (default: stesso SECRET_KEY JWT)
# SESSION_SECRET=

# Template .pptx (locale + manifest). Se TEMPLATE_MANIFEST_URL è impostato, i template si usano automaticamente
# (non serve USE_PPTX_TEMPLATES=1). Per forzare solo il renderer nativo: USE_PPTX_TEMPLATES=0
# USE_PPTX_TEMPLATES=1

# Template PPTX remoto (es. Cloudflare R2 public)
# Manifest JSON: { "templates": [ { "id":"boxvie", "url":"https://.../boxvie.pptx" } ] }
# URL pubblico del manifest JSON su R2 (stesso dominio dei .pptx). Va impostato anche sul server di produzione.
# TEMPLATE_MANIFEST_URL=https://pub-....r2.dev/manifest.json

# Con template .pptx: testo scuro su sfondo chiaro (default). Template master scuri: VOICEMINT_TEMPLATE_USE_THEME_TEXT=1
# VOICEMINT_TEMPLATE_USE_THEME_TEXT=1

# Foto tematiche nel PPTX nativo (titolo + fascia “studio”). Gratuito: https://www.pexels.com/api/
# Senza chiave: solo layout vettoriale (pannelli, accenti) differenziati studio vs presentazione.
# PEXELS_API_KEY=
# ENABLE_STOCK_IMAGES=1
# Max slide contenuto con foto a destra (Pexels per titolo slide). 0 = disabilita.
# MAX_INLINE_SLIDE_IMAGES=5
# Decorazioni geometriche extra sulle slide contenuto (1=on)
# ENABLE_NATIVE_PPTX_DECOR=1

# --- LLM generazione deck (nlp_parser) ---
# Chiave Groq (default se non usi altri provider)
# GROQ_API_KEY=

# Google Gemini e Anthropic (opzionali; per struttura/slide con modelli “forti”)
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Pipeline: split = passo 1 struttura + passo 2 JSON slide; legacy = una sola chiamata come prima
# VOICEMINT_PIPELINE_MODE=split

# Provider per fase struttura (gerarchia, sezioni): groq | gemini | anthropic
# VOICEMINT_STRUCTURE_PROVIDER=groq
# VOICEMINT_STRUCTURE_MODEL=

# Provider per generazione JSON slide completo
# VOICEMINT_SLIDE_PROVIDER=groq
# VOICEMINT_SLIDE_MODEL=

# Fix conteggio slide / espansione densità (spesso Groq per velocità)
# VOICEMINT_EXPAND_PROVIDER=groq
# VOICEMINT_EXPAND_MODEL=
