# URL pubblico del backend (deve coincidere con i redirect OAuth registrati su Google/GitHub)
BACKEND_PUBLIC_URL=https://voicemint-backend.onrender.com

# URL del frontend (dove si torna dopo il login OAuth)
FRONTEND_URL=https://www.voicemint.it

# Google OAuth (Console → Credenziali → ID client OAuth 2.0)
# Redirect autorizzato: {BACKEND_PUBLIC_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Settings → Developer settings → OAuth Apps)
# Authorization callback URL: {BACKEND_PUBLIC_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Opzionale: cookie sessione OAuth (default: stesso SECRET_KEY JWT)
# SESSION_SECRET=

# Template .pptx (locale + manifest). Default 0 = disabilitato; il deck usa solo il renderer nativo (layout variabili).
# USE_PPTX_TEMPLATES=1

# Template PPTX remoto (es. Cloudflare R2 public)
# Manifest JSON: { "templates": [ { "id":"boxvie", "url":"https://.../boxvie.pptx" } ] }
# URL pubblico del manifest JSON su R2 (stesso dominio dei .pptx). Va impostato anche sul server di produzione.
# TEMPLATE_MANIFEST_URL=https://pub-....r2.dev/manifest.json
